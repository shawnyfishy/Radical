# RADICAL — Required Environment Variables
# Copy this file to .env and fill in the real values for local dev.
# On Vercel, set these in the dashboard under Settings > Environment Variables.

# JWT Authentication
JWT_SECRET=your-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# ICICI Bank Payment Gateway
ICICI_MID=your-merchant-id
ICICI_KEY=your-aes-encryption-key
ICICI_AGG_ID=your-aggregator-id
ICICI_SALE_API=https://pgpayuat.icicibank.com/tsp/pg/api/v2/initiateSale

# Google Sheets Order Webhook
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Deployment
NODE_ENV=development
PORT=3000

# Turso Cloud Database
TURSO_DATABASE_URL=libsql://radical-shawnyfishy.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

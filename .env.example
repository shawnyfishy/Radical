# RADICAL — Required Environment Variables
# Copy this file to .env and fill in the real values for local dev.
# On Vercel, set these in the dashboard under Settings > Environment Variables.

# JWT Authentication
JWT_SECRET=your-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Google Sheets Order Webhook
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Deployment
NODE_ENV=development
PORT=3000

# Turso Cloud Database
TURSO_DATABASE_URL=libsql://radical-shawnyfishy.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# Google Sheets Webhook URL
SHEETS_WEBHOOK_URL=your_apps_script_web_app_url_here

# Delhivery Logistics API Configuration
DELHIVERY_API_KEY=your_delhivery_api_key_here
DELHIVERY_ENV=staging

# Delhivery Seller & Pickup Location
# IMPORTANT: DELHIVERY_PICKUP_LOCATION_NAME must exactly match the name
# registered in your Delhivery seller dashboard under Client Warehouses,
# or shipment creation will fail. Check there before setting this.
DELHIVERY_SELLER_NAME=RADICAL
DELHIVERY_SELLER_ADDRESS=City Centre, unit no. 320, 3rd Floor, Sector-12, Sai Road City Centre, Dwarka, New Delhi
DELHIVERY_SELLER_PIN=110078
DELHIVERY_SELLER_CITY=New Delhi
DELHIVERY_SELLER_STATE=Delhi
DELHIVERY_PICKUP_LOCATION_NAME=RADICAL Inc
